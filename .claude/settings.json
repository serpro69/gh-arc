{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "enabledMcpjsonServers": [],
  "enabledPlugins": {
    "kk@claude-toolbox": true
  },
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "CLAUDE_STATUSLINE_MODE": "dark",
    "CLAUDE_STATUSLINE_THEME": "catppuccin",
    "MAX_MCP_OUTPUT_TOKENS": "64000"
  },
  "extraKnownMarketplaces": {
    "claude-toolbox": {
      "source": {
        "source": "github",
        "repo": "serpro69/claude-toolbox"
      }
    }
  },
  "model": "opus",
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(go build:*)",
      "Bash(go get:*)",
      "Bash(go list:*)",
      "Bash(go mod:*)",
      "Bash(go test:*)",
      "Bash(go tool cover:*)",
      "Bash(chmod:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(sort:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs",
      "mcp__serena__get_symbols_overview",
      "mcp__serena__find_file",
      "mcp__serena__find_symbol",
      "mcp__serena__insert_after_symbol",
      "mcp__serena__insert_before_symbol",
      "mcp__serena__list_dir",
      "mcp__serena__replace_symbol_body",
      "mcp__serena__search_for_pattern",
      "mcp__serena__think_about_collected_information",
      "mcp__zen__codereview",
      "WebSearch"
    ],
    "ask": [],
    "deny": [
      "Bash(rm:*)",
      "Read(./examples)",
      "Read(./**/consensus*.md)",
      "Read(./**/review*.md)",
      "Read(./**/.env)",
      "Read(./**/service-account-key.json)",
      "Read(*.csv)",
      "Read(*.log)",
      "Read(*.pyc)",
      "Read(./**/*.lock*)",
      "Read(.git/)",
      "Read(.idea/)",
      "Read(.vscode/)",
      "Read(.next/)",
      "Read(./**/.ansible/)",
      "Read(./**/.terraform/)",
      "Read(./**/build/)",
      "Read(./**/data/)",
      "Read(./**/dist/)",
      "Read(./**/out/)",
      "Read(./**/node_modules/)",
      "Read(./**/venv/)",
      "Read(./**/__pycache__/)"
    ],
    "defaultMode": "default"
  },
  "statusLine": {
    "command": "bash $CLAUDE_PROJECT_DIR/.claude/scripts/statusline_enhanced.sh",
    "type": "command"
  },
  "effortLevel": "high"
}
